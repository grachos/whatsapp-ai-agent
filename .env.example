# ─── Server ──────────────────────────────────────────────
PORT=3000
API_KEY=change-me-dashboard-secret

# ─── OpenRouter ──────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ─── Groq (free Whisper transcription for voice notes) ──
# Get a free key at https://console.groq.com (no credit card)
# Without this, voice notes get a "voice not supported" reply.
GROQ_API_KEY=gsk_...
GROQ_WHISPER_MODEL=whisper-large-v3-turbo

# ─── Google Service Account ──────────────────────────────
GOOGLE_SERVICE_ACCOUNT_EMAIL=agent@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── Google Sheets ────────────────────────────────────────
GOOGLE_SHEETS_SPREADSHEET_ID=1Abc...xyz
INVENTORY_SHEET_NAME=Inventory
RESERVATIONS_SHEET_NAME=Reservations
CONFIG_SHEET_NAME=Config

# ─── Google Calendar ──────────────────────────────────────
GOOGLE_CALENDAR_ID=primary

# ─── Feature Flags ────────────────────────────────────────
WHATSAPP_IGNORE_GROUPS=true
# Anti-ban send throttle: min delay + random extra (jitter) between consecutive
# outgoing messages, in milliseconds. A lone reply is sent immediately; only
# back-to-back sends are spaced out to mimic human pacing.
WHATSAPP_SEND_MIN_DELAY_MS=1200
WHATSAPP_SEND_JITTER_MS=1500
SYNC_INTERVAL_MINUTES=15
LOCK_TTL_SECONDS=30
MAX_CONVERSATION_HISTORY=20
INVENTORY_CACHE_TTL_SECONDS=120
NODE_ENV=development
